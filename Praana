<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Amandeep AuraForge</title>
    <style>
        body { margin: 0; background: #000; color: #D4AF37; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; overflow: hidden; }
        #logo { font-size: 3.5rem; letter-spacing: 12px; text-shadow: 0 0 20px #D4AF37; cursor: pointer; transition: 0.5s; user-select: none; -webkit-tap-highlight-color: transparent; }
        #status { position: absolute; bottom: 15%; font-size: 0.8rem; opacity: 0.6; letter-spacing: 3px; text-align: center; width: 100%; text-transform: uppercase; }
    </style>
</head>
<body onclick="activateSiddhi()">
    <div id="logo">AMANDEEP</div>
    <div id="status">TOUCH LOGO TO START FORGE</div>
    <script>
        function activateSiddhi() {
            const status = document.getElementById('status');
            const logo = document.getElementById('logo');
            const sequence = [100, 200, 300, 400, 600, 700, 800, 900, 1000, 100, 200, 300, 400, 600, 900, 800, 900];
            if (navigator.vibrate) {
                navigator.vibrate(sequence);
                status.innerText = "SIDDHI ACTIVE: 12346... 989";
                logo.style.textShadow = "0 0 50px #D4AF37, 0 0 100px #FFF";
                setTimeout(() => {
                    logo.style.textShadow = "0 0 20px #D4AF37";
                    status.innerText = "FORGE COMPLETE - VAULT LOCKED";
                }, 8000);
            }
        }
    </script>
</body>
</html>
